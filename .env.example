# Solana devnet master keypair (base58 secret key). Server-only — never
# expose to the client, never commit the real value.
SOLANA_MASTER_PRIVATE_KEY=

# devnet | mainnet — must match everywhere in lib/txline/config.ts
TXLINE_NETWORK=devnet

# Google Gemini API key for narrative generation
GEMINI_API_KEY=

# Devnet odds sampling cadence (ms) — also gates AI narrative cooldown
TXLINE_SCORE_DELAY_MS=60000

# --- Throughput / rate limits (authless multi-user) ---
# RATE_LIMIT_API_PER_MIN=120
# RATE_LIMIT_BOARD_PER_MIN=40
# RATE_LIMIT_STREAM_CONNECT_PER_MIN=20
# RATE_LIMIT_CHAT_PER_MIN=15
# RATE_LIMIT_MAX_STREAMS_PER_IP=3

# --- SSE hub (one TxLINE upstream per fixture, fan-out to clients) ---
# HUB_MAX_CHANNELS=32
# HUB_MAX_SUBSCRIBERS=200
# HUB_IDLE_SHUTDOWN_MS=90000

# --- Response caches (ms) ---
# CACHE_BOARD_LIVE_MS=15000
# CACHE_SCORE_SNAPSHOT_MS=5000
# CACHE_ODDS_SNAPSHOT_MS=30000
